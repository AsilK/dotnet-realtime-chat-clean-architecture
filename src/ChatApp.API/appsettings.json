{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Database=chatapp;Username=chatapp;Password=change-me"
  },
  "Redis": {
    "ConnectionString": "localhost:6379"
  },
  "JwtSettings": {
    "Secret": "replace-this-with-a-strong-256-bit-secret-key-for-production",
    "Issuer": "ChatApp",
    "Audience": "ChatApp.Users",
    "AccessTokenExpirationMinutes": 15,
    "RefreshTokenExpirationDays": 7
  },
  "Smtp": {
    "Enabled": false,
    "Host": "smtp.sendgrid.net",
    "Port": 587,
    "UseSsl": true,
    "Username": "apikey",
    "Password": "",
    "FromEmail": "no-reply@chatapp.local",
    "FromName": "ChatApp"
  },
  "EmailQueue": {
    "Capacity": 1000,
    "MaxRetryAttempts": 3,
    "SendTimeoutSeconds": 10,
    "InitialRetryDelayMilliseconds": 500
  },
  "RefreshTokenCleanup": {
    "Enabled": true,
    "IntervalHours": 6,
    "RetentionDays": 30
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.Seq" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      { "Name": "Seq", "Args": { "serverUrl": "http://localhost:5341" } }
    ],
    "Enrich": [ "FromLogContext" ],
    "Properties": {
      "Application": "ChatApp.API"
    }
  },
  "AllowedHosts": "*"
}
